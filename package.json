{
  "name": "skyland-3-launcher",
  "version": "1.0.3",
  "description": "SKYLAND 3",
  "main": "src/main/main.js",
  "productName": "SKYLAND 3",
  "author": "Berklast",
  "repository": {
    "type": "git",
    "url": "https://github.com/berklast/SkylandLauncher.git"
  },
  "license": "MIT",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dev": "node scripts/start-electron.js",
    "build": "node scripts/build-installer.js",
    "pack": "electron-builder --dir",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "minecraft-launcher-core": "^3.18.2"
  },
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "rcedit": "^4.0.1"
  },
  "build": {
    "appId": "com.skyland3.launcher",
    "productName": "SKYLAND 3",
    "copyright": "Copyright (c) 2026 Berklast",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "afterPack": "scripts/after-pack.js",
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "node_modules/7zip-bin/win/x64/7za.exe",
        "to": "tools/7za.exe"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "legalTrademarks": "Berklast",
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "SKYLAND 3",
      "uninstallDisplayName": "SKYLAND 3",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "berklast",
        "repo": "SkylandLauncher"
      }
    ],
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
  }
}
